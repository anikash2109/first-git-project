   "source": [
    "def create_greeting(prefix):\n",
    "    def inner(name):\n",
    "        return f\" {prefix } {name},\"\n",
    "\n",
    "    return inner \n",
    "\n",
    "ani = create_greeting(\"Hi\")\n",
    "ani(\"Aniket\")"
   ]
